# Public variables (safe to expose in client-side code)
VITE_PUBLIC_EMAIL=your.email@gmail.com
VITE_PUBLIC_GITHUB=https://github.com/smallchungus
VITE_PUBLIC_LINKEDIN=https://linkedin.com/in/yourprofile

# Analytics (optional)
VITE_GA_TRACKING_ID=
VITE_HOTJAR_ID=

# Add these in Vercel dashboard as environment variables (keep secret)
# These are used for contact forms, analytics, etc.
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id  
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# GitHub API for fetching live repository stats (optional)
VITE_GITHUB_TOKEN=your_github_personal_access_token

# Vercel deployment secrets (add to GitHub repository secrets)
# VERCEL_TOKEN=your_vercel_token
# VERCEL_ORG_ID=your_vercel_org_id
# VERCEL_PROJECT_ID=your_vercel_project_id