# Notion CMS Integration
# Get these from your Notion workspace:
# 1. NOTION_API_KEY: Create an integration at https://www.notion.so/my-integrations
# 2. NOTION_DATABASE_ID: The 32-character ID from your database URL
#    Example URL: https://notion.so/myworkspace/{database_id}?v=...

NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
